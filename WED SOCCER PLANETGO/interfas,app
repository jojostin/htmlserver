<title>SOCCER PLANETGO</title>

<style>
body {
    margin: 0;
    background: #0b0b0f;
    color: white;
    font-family: Arial, sans-serif;
    padding-bottom: 70px;
}

/* HEADER */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    background: rgba(0,0,0,0.8);
    position: sticky;
    top: 0;
    backdrop-filter: blur(10px);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.header:active {
    transform: scale(0.97);
    box-shadow: 0 6px 20px rgba(0,0,0,0.6);
}

/* HERO */
.hero {
    height: 180px;
    margin: 10px;
    border-radius: 15px;
    overflow: hidden;
    position: relative;
}

.hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.hero-text {
    position: absolute;
    bottom: 15px;
    left: 15px;
    background: rgba(0,0,0,0.4);
    padding: 6px 12px;
    border-radius: 8px;
}

/* SECCIONES */
.section { padding: 10px; }
.row { display: flex; overflow-x: auto; gap: 10px; }

/* CARD */
.card {
    min-width: 140px;
    height: 90px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
    cursor: pointer;
}

.card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.card span {
    position: absolute;
    bottom: 5px;
    left: 5px;
    font-size: 12px;
    background: rgba(0,0,0,0.5);
    padding: 3px 6px;
    border-radius: 5px;
}

/* 🔥 MENÚ */
.bottom-menu {
    position: fixed;
    bottom: 0;
    width: 100%;
    background: #0b0f1a;
    display: flex;
    justify-content: space-around;
    padding: 8px 0;
}

.menu-item {
    text-align: center;
    color: #aaa;
}

.menu-item.active {
    color: red;
}
</style>
</head>

